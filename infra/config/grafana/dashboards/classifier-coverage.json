{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "title": "ENEL · Classifier Coverage",
  "tags": ["enel", "ml", "classifier", "erro-leitura"],
  "schemaVersion": 39,
  "style": "dark",
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Indefinido ratio por região",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "enel_classifier_indefinido_ratio",
          "legendFormat": "{{regiao}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Maior indefinido ratio atual",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "max(enel_classifier_indefinido_ratio)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latência da view classifier_coverage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(enel_aggregation_latency_seconds_bucket{view_id=\"classifier_coverage\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache hit ratio · classifier views",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "sum by (view_id) (rate(enel_cache_events_total{layer=\"memory\",route=\"aggregation\",result=\"hit\",view_id=~\"classifier_.*\"}[10m])) / clamp_min(sum by (view_id) (rate(enel_cache_events_total{layer=\"memory\",route=\"aggregation\",view_id=~\"classifier_.*\"}[10m])), 1)",
          "legendFormat": "{{view_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
