# Caddy reverse proxy — cutover React (web) default, Streamlit em /legacy.
#
# Para gerar hash de senha:
#   docker run --rm caddy caddy hash-password --plaintext 'suasenha'

{
	admin off
	auto_https off
	servers {
		protocols h1 h2c
	}
}

:8080 {
	encode gzip zstd

	# basicauth {
	#     enel JDJhJDE0JHBsYWNlaG9sZGVyX3JlcGxhY2VfbWVfd2l0aF9hX3JlYWxfaGFzaA
	# }

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Stream SSE: desabilita buffering e estende timeout p/ RAG.
	@sse path /v1/rag/stream*
	reverse_proxy @sse api:8000 {
		flush_interval -1
		transport http {
			read_timeout 600s
		}
	}

	# API + métricas: roteamento direto ao backend.
	handle /v1/* {
		reverse_proxy api:8000
	}
	handle /metrics {
		reverse_proxy api:8000
	}

	# Default: React SPA (nginx serve index.html + assets + try_files).
	handle {
		reverse_proxy web:8080
	}

	log {
		output stdout
		format console
	}
}
